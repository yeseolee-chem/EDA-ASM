    2 H      -0.075   -1.554   -0.629   -0.098   -1.346   -0.444   -0.107   -1.381   -0.488    0.141
    3 Br    -28.174   -6.517    0.309  -28.228   -6.557    0.215  -28.170   -6.581    0.249   -0.060
    4 C      -2.273   -3.061    0.666   -2.491   -3.110    0.399   -2.301   -3.063    0.637   -0.029
    5 H      -0.076   -1.509   -0.585   -0.099   -1.318   -0.417   -0.110   -1.386   -0.495    0.089
