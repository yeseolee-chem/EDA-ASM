    3 Cl    -11.016   -5.799    0.186  -11.100   -5.768    0.132  -11.013   -5.877    0.110   -0.076
    4 C      -2.271   -3.067    0.663   -2.470   -3.104    0.425   -2.298   -3.044    0.658   -0.005
    5 H      -0.075   -1.504   -0.579   -0.098   -1.316   -0.414   -0.109   -1.376   -0.485    0.094
