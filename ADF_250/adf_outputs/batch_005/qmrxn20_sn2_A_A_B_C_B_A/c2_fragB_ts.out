    9 O      -3.312   -4.811   -0.122   -3.499   -4.590   -0.088   -3.340   -4.956   -0.296   -0.174
   10 C      -2.093   -3.819    0.088   -2.185   -3.673    0.142   -2.116   -3.756    0.128    0.041
