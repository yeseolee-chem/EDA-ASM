    8 H      -0.080   -1.520   -0.599   -0.093   -1.333   -0.427   -0.107   -1.322   -0.429    0.170
    9 H      -0.079   -1.480   -0.559   -0.091   -1.318   -0.409   -0.107   -1.288   -0.395    0.165
   10 C      -2.279   -3.641    0.080   -2.437   -3.434    0.129   -2.318   -3.549    0.133    0.053
